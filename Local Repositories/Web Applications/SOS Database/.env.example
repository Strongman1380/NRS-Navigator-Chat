# Firebase client (hardcoded in src/config/firebase.js)
# VITE_FIREBASE_API_KEY=AIzaSyDVeGPicpLS6t2M0rmdXsHAXMVlXELgD5I
# VITE_FIREBASE_AUTH_DOMAIN=sos-data-log-73af3.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=sos-data-log-73af3
VITE_REQUIRE_ACCESS_GATE=false

# Server-side Firebase Admin (for API routes)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=sos-data-log-73af3

# Admin controls
ADMIN_EMAILS=bhinrichs1380@gmail.com
ALLOWED_EMAILS=
REQUIRE_EMAIL_VERIFIED=true
REQUIRE_SOS_ACCESS_CLAIM=true
REQUIRE_ACTIVE_ACCOUNT=true
REQUIRE_APP_CHECK=true

# App Check (Web)
VITE_APP_CHECK_SITE_KEY=

# First-party access gate
REQUIRE_ACCESS_GATE=false
ACCESS_GATE_PASSPHRASE=
# 32+ character random secret
ACCESS_GATE_SECRET=
ACCESS_GATE_TTL_SECONDS=43200
REQUIRE_STRONG_ACCESS_GATE_SECRET=true
ACCESS_GATE_RATE_LIMIT_REQUESTS=90
ACCESS_GATE_RATE_LIMIT_WINDOW_MS=60000
ACCESS_GATE_MAX_ATTEMPTS=10
ACCESS_GATE_ATTEMPT_WINDOW_MS=300000

# Field-level encryption
# 32-byte key, base64 encoded
FIELD_ENCRYPTION_KEY=
REQUIRE_FIELD_ENCRYPTION=true
# Optional key-ring format for rotations:
# FIELD_ENCRYPTION_KEYS={"v1":"<base64-32-byte-key>","v2":"<base64-32-byte-key>"}
# CURRENT_ENCRYPTION_KEY_ID=v2

# Rate limiting
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_MS=60000

# Backup drill defaults
FIRESTORE_BACKUP_URI_PREFIX=

# OpenAI (future)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# App
APP_ID=sos-case-notes-v1
